# milli-mala-multi-tenant — required environment variables
#
# This file is a TEMPLATE. Do not commit real values. Copy to a private
# .env (gitignored) for local development, or — in production — provision
# these as flat secrets on the deployment platform.
#
# All variables below are required at startup. The container will fail to
# start if any are missing or empty (see src/env.ts:requireEnv).
#
# Tenant structure is defined in src/tenants.config.ts. Each tenant carries
# its own values end-to-end (Zendesk subdomain/email/credentials, archive
# system URL/credentials, Málaskrá API key). This both isolates blast radius
# across tenants and keeps operationally-sensitive values out of the public
# repository.
#
# Adding a tenant: PR a new entry to src/tenants.config.ts, then provision
# the env vars listed by the requireEnv calls in that entry.

# ─── Service settings ───────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info
AUDIT_SECRET=
AUDIT_DIR=./audit-data

# ─── Kerfisstjórn — brand_id 33979373713298 — OneSystems endpoint ───────
KERFISSTJORN_ZENDESK_SUBDOMAIN=
KERFISSTJORN_ZENDESK_EMAIL=
KERFISSTJORN_ZENDESK_API_TOKEN=
KERFISSTJORN_ZENDESK_WEBHOOK_SECRET=
KERFISSTJORN_ONESYSTEMS_BASE_URL=
KERFISSTJORN_ONESYSTEMS_APP_KEY=
KERFISSTJORN_MALASKRA_API_KEY=

# ─── Vinnueftirlitið — brand_id 33979400825874 — GoPro endpoint ─────────
VINNUEFTIRLIT_ZENDESK_SUBDOMAIN=
VINNUEFTIRLIT_ZENDESK_EMAIL=
VINNUEFTIRLIT_ZENDESK_API_TOKEN=
VINNUEFTIRLIT_ZENDESK_WEBHOOK_SECRET=
VINNUEFTIRLIT_GOPRO_BASE_URL=
VINNUEFTIRLIT_GOPRO_USERNAME=
VINNUEFTIRLIT_GOPRO_PASSWORD=
VINNUEFTIRLIT_MALASKRA_API_KEY=

# ─── Samgöngustofa — brand_id 11037960588818 — OneSystems endpoint ──────
SAMGONGUSTOFA_ZENDESK_SUBDOMAIN=
SAMGONGUSTOFA_ZENDESK_EMAIL=
SAMGONGUSTOFA_ZENDESK_API_TOKEN=
SAMGONGUSTOFA_ZENDESK_WEBHOOK_SECRET=
SAMGONGUSTOFA_ONESYSTEMS_BASE_URL=
SAMGONGUSTOFA_ONESYSTEMS_APP_KEY=
SAMGONGUSTOFA_MALASKRA_API_KEY=
